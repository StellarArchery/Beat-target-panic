<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Archery App</title>
    <style>
        body { font-family: sans-serif; text-align: center; background: #121212; color: white; padding: 20px; }
        .stats { display: flex; justify-content: space-around; margin-bottom: 20px; }
        .box { background: #1e1e1e; padding: 15px; border-radius: 10px; border: 1px solid #444; min-width: 80px; }
        #coin { width: 120px; height: 120px; border-radius: 50%; border: 5px solid gold; margin: 20px auto; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem; background: #222; }
        #instruction { background: #1e1e1e; padding: 20px; border-radius: 10px; margin: 20px 0; min-height: 60px; border-left: 5px solid gold; }
        .main-btn { background: gold; color: black; border: none; padding: 20px; width: 100%; max-width: 300px; font-size: 1.2rem; font-weight: bold; border-radius: 10px; cursor: pointer; }
        .controls { display: flex; justify-content: center; gap: 40px; margin-top: 30px; }
        .score-btn { width: 70px; height: 70px; border-radius: 50%; border: none; font-size: 2rem; color: white; cursor: pointer; }
        .plus { background: green; }
        .minus { background: red; }
        .reset { background: none; border: 1px solid #444; color: #666; margin-top: 40px; padding: 5px 10px; cursor: pointer; }
        .lang { margin-bottom: 20px; }
        .lang button { background: #333; color: white; border: 1px solid #555; padding: 5px 10px; }
        .active { background: gold !important; color: black !important; }
    </style>
</head>
<body>

    <div class="lang">
        <button id="sk" class="active" onclick="zmenJazyk('sk')">SK</button>
        <button id="en" onclick="zmenJazyk('en')">EN</button>
    </div>

    <div class="stats">
        <div class="box">Hody: <span id="hody">0</span></div>
        <div class="box">Skóre: <span id="skore">0</span></div>
    </div>

    <div id="coin">?</div>
    <div id="instruction">Priprav sa na čiaru...</div>

    <button class="main-btn" onclick="hodit()">HODIŤ MINCOU</button>

    <div class="controls">
        <button class="score-btn minus" onclick="zmenBod(-1)">-</button>
        <button class="score-btn plus" onclick="zmenBod(1)">+</button>
    </div>

    <button class="reset" onclick="reset()">RESET</button>

    <script>
        var body = 0;
        var hody = 0;
        var jazyk = 'sk';

        var texty = {
            sk: { head: "HLAVA", tail: "OREL", shot: "VÝSTREL: Perfektný proces. Mantra 'Ťahám...', prekvapivý výstrel.", down: "LET DOWN: Mier na stred 6s, drž pin a potom zlož.", roll: "HODIŤ MINCOU", reset: "Naozaj reset?" },
            en: { head: "HEADS", tail: "TAILS", shot: "SHOT: Focus on process. Mantra 'Pulling...', surprise release.", down: "LET DOWN: Aim for 6s, hold the pin, then let down.", roll: "TOSS COIN", reset: "Really reset?" }
        };

        function zmenJazyk(p) {
            jazyk = p;
            document.getElementById('sk').className = (p == 'sk' ? 'active' : '');
            document.getElementById('en').className = (p == 'en' ? 'active' : '');
            document.querySelector('.main-btn').innerText = texty[p].roll;
        }

        function hodit() {
            hody++;
            document.getElementById('hody').innerText = hody;
            var vysledok = Math.random() < 0.5;
            var c = document.getElementById('coin');
            var i = document.getElementById('instruction');

            if (vysledok) {
                c.innerText = texty[jazyk].head;
                c.style.borderColor = "green";
                i.innerHTML = "<strong>" + texty[jazyk].shot + "</strong>";
            } else {
                c.innerText = texty[jazyk].tail;
                c.style.borderColor = "blue";
                i.innerHTML = "<strong>" + texty[jazyk].down + "</strong>";
            }
        }

        function zmenBod(v) {
            body += v;
            document.getElementById('skore').innerText = body;
        }

        function reset() {
            if (confirm(texty[jazyk].reset)) {
                body = 0; hody = 0;
                document.getElementById('skore').innerText = "0";
                document.getElementById('hody').innerText = "0";
                document.getElementById('coin').innerText = "?";
                document.getElementById('coin').style.borderColor = "gold";
                document.getElementById('instruction').innerText = "...";
            }
        }
    </script>
</body>
</html>
